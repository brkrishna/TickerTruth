# TickerTruth environment variables
# Copy this file to .env and fill in values before running the pipeline.
# .env is gitignored — never commit real credentials.

# ── Cloudflare R2 (required for artifact uploads and signed URL delivery) ──────
# Create an R2 bucket at dash.cloudflare.com → R2 → Create bucket
R2_BUCKET=tickertruth-releases
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Dolt identity (required for dolt commit) ───────────────────────────────────
# These are set via `dolt config --global`, not env vars, but documented here
# for reference:
#   dolt config --global --add user.name  "Your Name"
#   dolt config --global --add user.email "you@example.com"
